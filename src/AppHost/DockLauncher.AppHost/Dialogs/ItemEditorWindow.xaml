<Window x:Class="DockLauncher.AppHost.Dialogs.ItemEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="550"
        MinWidth="500"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Foreground="#F8FAFC"
        FontFamily="Segoe UI Variable Display, Segoe UI">
    <Border Margin="18"
            Padding="18"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource CardStroke}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Edit Item" />
                <TextBlock Margin="0,8,0,0"
                           Opacity="0.76"
                           TextWrapping="Wrap"
                           Text="{Binding HelperText}" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Margin="0,0,0,8"
                               Opacity="0.72"
                               Text="Display name" />
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Margin="0,0,0,8"
                               Opacity="0.72"
                               Text="Item type" />
                    <TextBlock VerticalAlignment="Center"
                               Padding="12,10"
                               Background="#182235"
                               Text="{Binding TypeLabel, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Margin="0,16,0,0">
                <TextBlock Margin="0,0,0,8"
                           Opacity="0.72"
                           Text="Icon path" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding IconPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding BrowseIconCommand}"
                            Content="Choose Icon..." />
                    <Button Grid.Column="2"
                            Margin="10,0,0,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ClearIconCommand}"
                            Content="Clear" />
                </Grid>

                <TextBlock Margin="0,14,0,8"
                           Opacity="0.72"
                           Text="Arguments" />
                <TextBox Height="86"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Margin="0,14,0,0"
                          Content="Run As Administrator"
                          IsChecked="{Binding RunAsAdministrator}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="#FFFCA5A5"
                           TextWrapping="Wrap"
                           Text="{Binding ValidationMessage}" />
            </StackPanel>

            <Grid Grid.Row="3"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Opacity="0.62"
                           Text="Changes apply to the stored launcher item." />

                <Button Grid.Column="1"
                        Margin="0,0,10,0"
                        Style="{StaticResource ActionButtonStyle}"
                        IsCancel="True"
                        Content="Cancel" />
                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"
                        Content="Save Item" />
            </Grid>
        </Grid>
    </Border>
</Window>

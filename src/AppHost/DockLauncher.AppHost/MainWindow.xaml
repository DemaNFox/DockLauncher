<Window x:Class="DockLauncher.AppHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DockLauncher Configurator"
        Width="1440"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Foreground="#F8FAFC"
        FontFamily="Segoe UI Variable Display, Segoe UI">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#0B1220" />
                <GradientStop Offset="0.5" Color="#0F172A" />
                <GradientStop Offset="1" Color="#111827" />
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 Margin="-120,-180,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="#2238BDF8"
                 IsHitTestVisible="False" />
        <Ellipse Width="520"
                 Height="520"
                 Margin="0,0,-180,-220"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="#1414B8A6"
                 IsHitTestVisible="False" />

        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="24"
                    Background="#66111C2D"
                    BorderBrush="#2B3B52"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Width="108"
                                Padding="10,4"
                                Background="#1538BDF8"
                                BorderBrush="#3338BDF8"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="CONFIGURATION" />
                        </Border>
                        <TextBlock Margin="0,18,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Text="DockLauncher Configurator" />
                        <TextBlock Margin="0,10,0,0"
                                   MaxWidth="620"
                                   Opacity="0.8"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                  Text="Manage dock panels, icon behavior and workspace content here. Runtime panels preview changes immediately, while Save commits them to disk." />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               ItemHeight="40"
                               ItemWidth="128">
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding Workspace.ImportWorkspaceCommand}"
                                Content="Import" />
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding Workspace.ExportWorkspaceCommand}"
                                Content="Export" />
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding Workspace.ResetLayoutCommand}"
                                Content="Reset Layout" />
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding Workspace.ReloadCommand}"
                                Content="Reload" />
                        <Button Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding Workspace.SaveCommand}"
                                Content="Save Workspace" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,24,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                        Padding="18"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardStroke}"
                        BorderThickness="1"
                        CornerRadius="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Panels" />
                            <TextBlock Margin="0,6,0,0"
                                       Opacity="0.72"
                                       Text="Create, rename and select the panel you want to edit." />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,20,0,18">
                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="New panel name" />
                            <TextBox Margin="0,0,0,12"
                                     Text="{Binding Workspace.DraftPanelName, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding Workspace.AddPanelCommand}"
                                        Content="Add Panel" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding Workspace.RemoveSelectedPanelCommand}"
                                        Content="Remove Panel" />
                            </Grid>
                        </StackPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Workspace.Panels}"
                                 SelectedItem="{Binding Workspace.SelectedPanel}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            CornerRadius="18"
                                            AllowDrop="True"
                                            Drop="OnPanelListItemDrop"
                                            DragOver="OnPanelListItemDragOver">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource CardBrushStrong}" />
                                                <Setter Property="BorderBrush" Value="#2A3A4E" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#263A55" />
                                                        <Setter Property="BorderBrush" Value="#FF38BDF8" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBox FontSize="16"
                                                     FontWeight="SemiBold"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Border Margin="0,0,8,8"
                                                        Padding="10,4"
                                                        Background="#12263A"
                                                        BorderBrush="#22354D"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock FontSize="11" Text="{Binding Position}" />
                                                </Border>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10,4"
                                                        Background="#12263A"
                                                        BorderBrush="#22354D"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock FontSize="11" Text="{Binding LayoutMode}" />
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="18"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardStroke}"
                        BorderThickness="1"
                        CornerRadius="24">
                        <TabControl SelectedIndex="{Binding SelectedEditorTabIndex}">
                        <TabItem Header="Design">
                            <ScrollViewer Margin="0,18,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <Border Padding="18"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Panel Layout" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Opacity="0.72"
                                                       Text="Configure docking, spacing, label scale and panel color for the runtime panel." />

                                            <StackPanel Margin="0,18,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Position" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelPositions}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.Position}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Layout Mode" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelLayoutModes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.LayoutMode}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Orientation" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelOrientations}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.Orientation}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Icon Size" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.IconSize, StringFormat={}{0:F0}px}" />
                                                <Slider Minimum="24"
                                                        Maximum="96"
                                                        TickFrequency="2"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding Workspace.SelectedPanel.IconSize}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Opacity" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.Opacity, StringFormat={}{0:F2}}" />
                                                <Slider Minimum="0.35"
                                                        Maximum="1"
                                                        TickFrequency="0.01"
                                                        Value="{Binding Workspace.SelectedPanel.Opacity}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Horizontal Padding" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.HorizontalPadding, StringFormat={}{0:F0}px}" />
                                                <Slider Minimum="0"
                                                        Maximum="48"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding Workspace.SelectedPanel.HorizontalPadding}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Vertical Padding" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.VerticalPadding, StringFormat={}{0:F0}px}" />
                                                <Slider Minimum="0"
                                                        Maximum="48"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding Workspace.SelectedPanel.VerticalPadding}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Panel Color" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="32"
                                                            Height="32"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding Workspace.SelectedPanel.PanelColorBrush}"
                                                            BorderBrush="#55F8FAFC"
                                                            BorderThickness="1"
                                                            CornerRadius="10" />
                                                    <Button Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            Style="{StaticResource ActionButtonStyle}"
                                                            Command="{Binding Workspace.PickPanelColorCommand}"
                                                            Content="Pick Panel Color" />
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Labels &amp; Behavior" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Opacity="0.72"
                                                       Text="Always-visible labels can sit above or below the icon. Hover labels auto-place away from the screen edge." />

                                            <StackPanel Margin="0,18,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Label Mode" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelLabelDisplayModes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.LabelDisplayMode}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Label Placement" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelLabelPlacements}"
                                                          IsEnabled="{Binding Workspace.SelectedPanel.LabelsVisible}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.LabelPlacement}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Icon Shape" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelIconShapes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.IconShape}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Flyout Display" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelFlyoutDisplayModes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.FlyoutDisplayMode}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Group Open Mode" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelGroupOpenModes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.GroupOpenMode}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Overflow Mode" />
                                                <ComboBox ItemsSource="{Binding Workspace.PanelOverflowModes}"
                                                          SelectedItem="{Binding Workspace.SelectedPanel.OverflowMode}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Max Rows / Columns" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.MaxOverflowTracks, StringFormat={}{0:F0}}" />
                                                <Slider Minimum="1"
                                                        Maximum="6"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding Workspace.SelectedPanel.MaxOverflowTracks}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Text Size" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.TextSize, StringFormat={}{0:F1}px}" />
                                                <Slider Minimum="9"
                                                        Maximum="22"
                                                        TickFrequency="0.5"
                                                        Value="{Binding Workspace.SelectedPanel.TextSize}" />
                                            </StackPanel>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Icon To Text Gap" />
                                                <TextBlock Opacity="0.68"
                                                           Text="{Binding Workspace.SelectedPanel.LabelSpacing, StringFormat={}{0:F0}px}" />
                                                <Slider Minimum="0"
                                                        Maximum="20"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding Workspace.SelectedPanel.LabelSpacing}" />
                                            </StackPanel>

                                            <CheckBox Margin="0,16,0,0"
                                                      Content="Always On Top"
                                                      IsChecked="{Binding Workspace.SelectedPanel.AlwaysOnTop}" />
                                            <CheckBox Content="Auto Hide"
                                                      IsEnabled="{Binding Workspace.SelectedPanel.CanAutoHide}"
                                                      IsChecked="{Binding Workspace.SelectedPanel.AutoHide}"
                                                      ToolTip="{Binding Workspace.SelectedPanel.AutoHideTooltip}"
                                                      ToolTipService.ShowOnDisabled="True" />
                                            <CheckBox Content="Lock Position"
                                                      IsChecked="{Binding Workspace.SelectedPanel.Locked}" />

                                            <Grid Margin="0,18,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Floating Left" />
                                                    <TextBox IsEnabled="{Binding Workspace.SelectedPanel.IsFloating}"
                                                             Text="{Binding Workspace.SelectedPanel.FloatingLeft, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Available only for floating panels."
                                                             ToolTipService.ShowOnDisabled="True" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Floating Top" />
                                                    <TextBox IsEnabled="{Binding Workspace.SelectedPanel.IsFloating}"
                                                             Text="{Binding Workspace.SelectedPanel.FloatingTop, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Available only for floating panels."
                                                             ToolTipService.ShowOnDisabled="True" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Margin="0,12,0,0">
                                                <TextBlock Margin="0,0,0,8"
                                                           Opacity="0.72"
                                                           Text="{Binding Workspace.SelectedPanel.DockOffsetLabel}" />
                                                <TextBox IsEnabled="{Binding Workspace.SelectedPanel.IsDocked}"
                                                         Text="{Binding Workspace.SelectedPanel.DockOffset, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="For Top/Bottom panels this is the offset from the left edge. For Left/Right panels this is the offset from the top edge. Leave empty to center."
                                                         ToolTipService.ShowOnDisabled="True" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Items">
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Add Item" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Opacity="0.72"
                                                       Text="{Binding Workspace.SelectedPanel.Name, StringFormat=Selected panel: {0}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,18,0,18">
                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Name" />
                                            <TextBox Margin="0,0,0,12"
                                                     Text="{Binding Workspace.DraftItemName, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Type" />
                                            <ComboBox Margin="0,0,0,12"
                                                      ItemsSource="{Binding Workspace.ItemTypes}"
                                                      SelectedItem="{Binding Workspace.DraftItemType}" />

                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Target" />
                                            <TextBox Margin="0,0,0,12"
                                                     Text="{Binding Workspace.DraftItemTarget, UpdateSourceTrigger=PropertyChanged}" />

                                            <ComboBox Margin="0,0,0,12"
                                                      ItemsSource="{Binding Workspace.BuiltInActions}"
                                                      SelectedItem="{Binding Workspace.SelectedBuiltInAction}"
                                                      DisplayMemberPath="DisplayName" />

                                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding Workspace.AddItemToSelectedPanelCommand}"
                                                    Content="Add Item To Panel" />
                                        </StackPanel>

                                        <Border Grid.Row="2"
                                                Padding="12"
                                                Background="#12263A"
                                                BorderBrush="#22354D"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <TextBlock Opacity="0.72"
                                                       TextWrapping="Wrap"
                                                       Text="Drop files, folders or shortcuts onto the items list to add them to the selected panel." />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Panel Items" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Opacity="0.72"
                                                           Text="{Binding Workspace.PanelItems.Count, StringFormat=Items: {0}}" />
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top">
                                                <Button Margin="0,0,10,0"
                                                        MinWidth="92"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding Workspace.LaunchSelectedItemCommand}"
                                                        Content="Launch" />
                                                <Button Margin="0,0,10,0"
                                                        MinWidth="92"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding Workspace.MoveSelectedItemToPanelCommand}"
                                                        Content="Move" />
                                                <Button MinWidth="92"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding Workspace.RemoveSelectedItemCommand}"
                                                        Content="Remove" />
                                            </WrapPanel>
                                        </Grid>

                                        <ListBox Grid.Row="1"
                                                 Margin="0,18,0,18"
                                                 AllowDrop="True"
                                                 Drop="OnPanelItemsDrop"
                                                 DragOver="OnPanelItemsDragOver"
                                                 ItemsSource="{Binding Workspace.PanelItems}"
                                                 SelectedItem="{Binding Workspace.SelectedPanelItem}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            CornerRadius="14"
                                                            Background="{StaticResource CardBrushStrong}"
                                                            BorderBrush="#2A3A4E"
                                                            BorderThickness="1"
                                                            PreviewMouseLeftButtonDown="OnItemCardPreviewMouseLeftButtonDown"
                                                            MouseMove="OnItemCardMouseMove"
                                                            DragOver="OnItemCardDragOver"
                                                            Drop="OnItemCardDrop">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="42" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="32"
                                                                    Height="32"
                                                                    VerticalAlignment="Top"
                                                                    Background="#1E293B"
                                                                    BorderBrush="#334155"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <Grid>
                                                                    <Image Width="20"
                                                                           Height="20"
                                                                           Source="{Binding IconSource}"
                                                                           Visibility="{Binding IconVisibility}" />
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Glyph}"
                                                                               Visibility="{Binding GlyphVisibility}" />
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBox FontSize="15"
                                                                         FontWeight="SemiBold"
                                                                         Background="Transparent"
                                                                         BorderThickness="0"
                                                                         Padding="0"
                                                                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           FontSize="12"
                                                                           Opacity="0.72"
                                                                           Text="{Binding Target}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <WrapPanel Margin="0,8,0,0">
                                                                    <Border Margin="0,0,8,0"
                                                                            Padding="8,3"
                                                                            Background="#12263A"
                                                                            BorderBrush="#22354D"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8">
                                                                        <TextBlock FontSize="11" Text="{Binding Type}" />
                                                                    </Border>
                                                                    <CheckBox Content="Admin"
                                                                              IsChecked="{Binding RunAsAdministrator}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Move target panel" />
                                                <ComboBox ItemsSource="{Binding Workspace.Panels}"
                                                          SelectedItem="{Binding Workspace.SelectedMoveTargetPanel}"
                                                          DisplayMemberPath="Name" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Arguments" />
                                                <TextBox Text="{Binding Workspace.SelectedPanelItem.Arguments, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Groups">

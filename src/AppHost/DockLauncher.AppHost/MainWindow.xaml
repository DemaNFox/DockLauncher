                                                    <Border Margin="0,0,0,12"
                                                            Padding="14"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            CornerRadius="18">
                                                        <TextBox Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 FontSize="15"
                                                                 FontWeight="SemiBold"
                                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Panel Item Shortcuts" />
                                        <StackPanel Grid.Row="1" Margin="0,18,0,18">
                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Source panel" />
                                            <ComboBox ItemsSource="{Binding Workspace.Panels}"
                                                      SelectedItem="{Binding Workspace.SelectedGroupSourcePanel}"
                                                      DisplayMemberPath="Name" />
                                            <Border Margin="0,10,0,0"
                                                    Padding="10,7"
                                                    Background="#1E38BDF8"
                                                    BorderBrush="#6638BDF8"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFE0F2FE"
                                                           Text="{Binding Workspace.SelectedGroupSourcePanel.Name, StringFormat=Working on: {0}}" />
                                            </Border>
                                        </StackPanel>
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding Workspace.GroupSourcePanelItems}"
                                                 SelectedItem="{Binding Workspace.SelectedGroupSourceItem}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            ToolTip="{Binding TooltipText}"
                                                            PreviewMouseLeftButtonDown="OnItemCardPreviewMouseLeftButtonDown"
                                                            MouseMove="OnItemCardMouseMove">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Width="42"
                                                                  Height="42"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Top">
                                                                <Border Background="{Binding AccentBrush}"
                                                                        CornerRadius="14"
                                                                        Visibility="{Binding GlyphVisibility}">
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               Foreground="#FF0B1220"
                                                                               Text="{Binding Glyph}" />
                                                                </Border>
                                                                <Image Width="42"
                                                                       Height="42"
                                                                       Stretch="Uniform"
                                                                       Source="{Binding IconSource}"
                                                                       Visibility="{Binding IconVisibility}" />
                                                            </Grid>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Opacity="0.62"
                                                                           Text="{Binding TypeLabel}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Opacity="0.72"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayPath}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <Button Grid.Row="3"
                                                Margin="0,12,0,0"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding Workspace.AddSelectedSourceItemToGroupCommand}"
                                                Content="Add Selected Shortcut" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4"
                                        Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        AllowDrop="True"
                                        Drop="OnGroupItemsDrop"
                                        DragOver="OnWorkspaceCollectionDragOver">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Selected Group Items" />
                                        <Grid Grid.Row="1" Margin="0,18,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding Workspace.RemoveSelectedItemFromGroupCommand}"
                                                    Content="Remove Selected Item" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding Workspace.AddSelectedGroupToPanelCommand}"
                                                    Content="Add Group To Panel" />
                                        </Grid>
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding Workspace.GroupItems}"
                                                 SelectedItem="{Binding Workspace.SelectedGroupItem}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 AllowDrop="True"
                                                 Drop="OnGroupItemsDrop"
                                                 DragOver="OnWorkspaceCollectionDragOver">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            ToolTip="{Binding TooltipText}"
                                                            AllowDrop="True"
                                                            Drop="OnGroupItemsDrop"
                                                            DragOver="OnWorkspaceCollectionDragOver">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Width="42"
                                                                  Height="42"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Top">
                                                                <Border Background="{Binding AccentBrush}"
                                                                        CornerRadius="14"
                                                                        Visibility="{Binding GlyphVisibility}">
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               Foreground="#FF0B1220"
                                                                               Text="{Binding Glyph}" />
                                                                </Border>
                                                                <Image Width="42"
                                                                       Height="42"
                                                                       Stretch="Uniform"
                                                                       Source="{Binding IconSource}"
                                                                       Visibility="{Binding IconVisibility}" />
                                                            </Grid>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Opacity="0.62"
                                                                           Text="{Binding TypeLabel}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Opacity="0.72"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayPath}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Launch Profiles">
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="2"
                                        Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Launch Profiles" />
                                        <StackPanel Grid.Row="1" Margin="0,18,0,18">
                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Profile name" />
                                            <TextBox Margin="0,0,0,12"
                                                     Text="{Binding Workspace.DraftLaunchProfileName, UpdateSourceTrigger=PropertyChanged}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding Workspace.AddLaunchProfileCommand}"
                                                        Content="Create Profile" />
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding Workspace.RemoveSelectedLaunchProfileCommand}"
                                                        Content="Remove Profile" />
                                            </Grid>
                                        </StackPanel>
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding Workspace.LaunchProfiles}"
                                                 SelectedItem="{Binding Workspace.SelectedLaunchProfile}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12"
                                                            Padding="14"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            CornerRadius="18">
                                                        <TextBox Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 FontSize="15"
                                                                 FontWeight="SemiBold"
                                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Panel Item Shortcuts" />
                                        <StackPanel Grid.Row="1" Margin="0,18,0,18">
                                            <TextBlock Margin="0,0,0,8" Opacity="0.72" Text="Source panel" />
                                            <ComboBox ItemsSource="{Binding Workspace.Panels}"
                                                      SelectedItem="{Binding Workspace.SelectedLaunchProfileSourcePanel}"
                                                      DisplayMemberPath="Name" />
                                            <Border Margin="0,10,0,0"
                                                    Padding="10,7"
                                                    Background="#1E38BDF8"
                                                    BorderBrush="#6638BDF8"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFE0F2FE"
                                                           Text="{Binding Workspace.SelectedLaunchProfileSourcePanel.Name, StringFormat=Working on: {0}}" />
                                            </Border>
                                        </StackPanel>
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding Workspace.LaunchProfileSourcePanelItems}"
                                                 SelectedItem="{Binding Workspace.SelectedLaunchProfileSourceItem}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            ToolTip="{Binding TooltipText}"
                                                            PreviewMouseLeftButtonDown="OnItemCardPreviewMouseLeftButtonDown"
                                                            MouseMove="OnItemCardMouseMove">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Width="42"
                                                                  Height="42"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Top">
                                                                <Border Background="{Binding AccentBrush}"
                                                                        CornerRadius="14"
                                                                        Visibility="{Binding GlyphVisibility}">
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               Foreground="#FF0B1220"
                                                                               Text="{Binding Glyph}" />
                                                                </Border>
                                                                <Image Width="42"
                                                                       Height="42"
                                                                       Stretch="Uniform"
                                                                       Source="{Binding IconSource}"
                                                                       Visibility="{Binding IconVisibility}" />
                                                            </Grid>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Opacity="0.62"
                                                                           Text="{Binding TypeLabel}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Opacity="0.72"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayPath}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <Button Grid.Row="3"
                                                Margin="0,12,0,0"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding Workspace.AddSelectedSourceItemToLaunchProfileCommand}"
                                                Content="Add Selected Shortcut" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4"
                                        Padding="16"
                                        Background="#A8111A28"
                                        BorderBrush="#223349"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        AllowDrop="True"
                                        Drop="OnLaunchProfileStepsDrop"
                                        DragOver="OnWorkspaceCollectionDragOver">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Profile Steps" />
                                        <Grid Grid.Row="1" Margin="0,18,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding Workspace.RemoveSelectedStepFromLaunchProfileCommand}"
                                                    Content="Remove Selected Step" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding Workspace.AddSelectedLaunchProfileToPanelCommand}"
                                                    Content="Add Profile To Panel" />
                                        </Grid>
                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding Workspace.SelectedLaunchProfileSteps}"
                                                 SelectedItem="{Binding Workspace.SelectedLaunchProfileStep}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12"
                                                            Padding="14"
                                                            Style="{StaticResource SelectableCardStyle}"
                                                            CornerRadius="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="112" />
                                                                <ColumnDefinition Width="156" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock FontWeight="SemiBold" Text="{Binding ItemDisplayName}" />
                                                                <TextBlock Margin="0,4,0,0" Opacity="0.58" Text="{Binding ItemId}" />
                                                            </StackPanel>
                                                            <TextBox Grid.Column="1"
                                                                     Margin="12,0"
                                                                     Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                                            <CheckBox Grid.Column="2"
                                                                      Margin="0"
                                                                      VerticalAlignment="Center"
                                                                      Content="Run As Admin"
                                                                      IsChecked="{Binding RunAsAdministrator}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

            </Grid>

            <Border Grid.Row="2"
                    Padding="14,12"
                    Background="#80111C2D"
                    BorderBrush="#2B3B52"
                    BorderThickness="1"
                    CornerRadius="18">
                <TextBlock Opacity="0.76"
                           Text="Next stretch goal: richer dock actions, tighter Windows shell integration and deeper panel personalization." />
            </Border>
        </Grid>
    </Grid>
</Window>

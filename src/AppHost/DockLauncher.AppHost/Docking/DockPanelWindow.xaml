<Window x:Class="DockLauncher.AppHost.Docking.DockPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docking="clr-namespace:DockLauncher.AppHost.Docking"
        ShowInTaskbar="False"
        ShowActivated="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowDrop="True"
        ContextMenuService.Placement="MousePoint"
        Topmost="{Binding IsTopmost}">
    <Window.Resources>
        <Style x:Key="DockButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{Binding DataContext.ItemSize, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Height" Value="{Binding DataContext.ItemSize, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RenderTransformOrigin"
                    Value="{Binding DataContext.DockItemTransformOrigin, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
            <Setter Property="ToolTipService.ShowDuration" Value="1600" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="CircleChrome"
                                     Width="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Height="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding DataContext.CircleShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Stroke="{Binding DataContext.IconHoverBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                     StrokeThickness="1.6"
                                     Opacity="0"
                                     Fill="{Binding DataContext.IconHoverBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.35"
                                                      Color="#FF000000" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Border x:Name="RoundedSquareChrome"
                                    Width="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding DataContext.RoundedSquareShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CornerRadius="{Binding DataContext.RoundedSquareCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                    BorderBrush="{Binding DataContext.IconHoverBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                    BorderThickness="1.6"
                                    Opacity="0"
                                    Background="{Binding DataContext.IconHoverBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.35"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="SquareChrome"
                                    Width="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding DataContext.SquareShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CornerRadius="0"
                                    BorderBrush="{Binding DataContext.IconHoverBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                    BorderThickness="1.6"
                                    Opacity="0"
                                    Background="{Binding DataContext.IconHoverBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.35"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>

                            <Polygon x:Name="HexagonChrome"
                                     Width="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Height="{Binding DataContext.IconChromeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding DataContext.HexagonShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Points="50,2 92,26 92,74 50,98 8,74 8,26"
                                     Stretch="Fill"
                                     Stroke="{Binding DataContext.IconHoverBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                     StrokeThickness="1.6"
                                     Opacity="0"
                                     Fill="{Binding DataContext.IconHoverBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Polygon.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.35"
                                                      Color="#FF000000" />
                                </Polygon.Effect>
                            </Polygon>

                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CircleChrome" Property="Opacity" Value="1" />
                                <Setter TargetName="RoundedSquareChrome" Property="Opacity" Value="1" />
                                <Setter TargetName="SquareChrome" Property="Opacity" Value="1" />
                                <Setter TargetName="HexagonChrome" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CircleChrome" Property="Opacity" Value="0.9" />
                                <Setter TargetName="RoundedSquareChrome" Property="Opacity" Value="0.9" />
                                <Setter TargetName="SquareChrome" Property="Opacity" Value="0.9" />
                                <Setter TargetName="HexagonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Add To Panel">
                <MenuItem Command="{Binding AddFileCommand}" Header="Add File" />
                <MenuItem Command="{Binding AddFolderCommand}" Header="Add Folder" />
                <MenuItem Command="{Binding AddSeparatorCommand}" Header="Add Separator" />
                <MenuItem Command="{Binding ImportPinnedShortcutsCommand}" Header="Import Pinned Shortcuts" />
                <Separator />
                <MenuItem Command="{Binding OpenGroupsEditorCommand}" Header="Create Group In Configurator" />
                <MenuItem Command="{Binding OpenLaunchProfilesEditorCommand}" Header="Create Launch Profile In Configurator" />
            </MenuItem>
            <Separator />
            <MenuItem Command="{Binding ShowConfiguratorCommand}" Header="Open Configurator" />
            <MenuItem Command="{Binding RenamePanelCommand}" Header="Rename Panel" />
            <MenuItem Command="{Binding DuplicatePanelCommand}" Header="Duplicate Panel" />
            <MenuItem Command="{Binding CreateEmptyPanelCommand}" Header="New Empty Panel" />
            <MenuItem Command="{Binding RemovePanelCommand}" Header="Remove Panel" />
            <MenuItem Command="{Binding HidePanelCommand}" Header="Hide Panel" />
            <MenuItem Command="{Binding TogglePanelLockCommand}"
                      Header="Lock Panel Position"
                      IsCheckable="True"
                      IsChecked="{Binding IsLocked, Mode=OneWay}" />
            <Separator />
            <MenuItem Header="Panel Appearance">
                <MenuItem Command="{Binding ToggleLabelsCommand}"
                          Header="Show Labels"
                          IsCheckable="True"
                          IsChecked="{Binding LabelsVisible, Mode=OneWay}" />
                <MenuItem Command="{Binding ToggleAlwaysOnTopCommand}"
                          Header="Always On Top"
                          IsCheckable="True"
                          IsChecked="{Binding IsTopmost, Mode=OneWay}" />
                <MenuItem Command="{Binding ToggleAutoHideCommand}"
                          Header="Auto Hide"
                          IsEnabled="{Binding CanAutoHide}"
                          IsCheckable="True"
                          IsChecked="{Binding AutoHideEnabled, Mode=OneWay}"
                          ToolTip="{Binding AutoHideTooltip}"
                          ToolTipService.ShowOnDisabled="True" />
                <Separator />
                <MenuItem Header="Orientation">
                    <MenuItem Command="{Binding SetHorizontalOrientationCommand}"
                              Header="Horizontal"
                              IsCheckable="True"
                              IsChecked="{Binding IsHorizontalOrientation, Mode=OneWay}" />
                    <MenuItem Command="{Binding SetVerticalOrientationCommand}"
                              Header="Vertical"
                              IsCheckable="True"
                              IsChecked="{Binding IsVerticalOrientation, Mode=OneWay}" />
                </MenuItem>
                <Separator />
                <MenuItem Command="{Binding IncreaseIconSizeCommand}" Header="Increase Icon Size" />
                <MenuItem Command="{Binding DecreaseIconSizeCommand}" Header="Decrease Icon Size" />
            </MenuItem>
            <MenuItem Command="{Binding RefreshPanelsCommand}" Header="Refresh Panels" />
            <Separator />
            <MenuItem Command="{Binding ExitCommand}" Header="Exit DockLauncher" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid x:Name="PanelShell">
    <Border x:Name="PanelChrome"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderThickness="1.2"
            CornerRadius="26"
            Padding="{Binding EffectivePanelPadding}"
            ClipToBounds="True"
            ToolTip="{Binding Title}"
            ToolTipService.InitialShowDelay="180"
            ToolTipService.ShowDuration="1800">
        <Border.Background>
            <Binding Path="PanelBackgroundBrush" />
        </Border.Background>
        <Border.BorderBrush>
            <Binding Path="PanelBorderBrush" />
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="0"
                              Opacity="0.42"
                              Color="#FF020617" />
        </Border.Effect>

        <Grid>
            <Border x:Name="PanelHoverOverlay"
                    Background="{Binding IconHoverBackgroundBrush}"
                    IsHitTestVisible="False"
                    Opacity="0" />

            <Grid x:Name="OverflowViewport"
                  ClipToBounds="True"
                  PreviewMouseWheel="OnOverflowViewportMouseWheel">
                <ScrollViewer x:Name="OverflowScrollViewer"
                              Margin="{Binding OverflowScrollViewerMargin}"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden"
                              CanContentScroll="False"
                              PanningMode="Both">
                    <ItemsControl x:Name="OverflowItemsHost"
                                  HorizontalAlignment="{Binding OverflowItemsHorizontalAlignment}"
                                  VerticalAlignment="{Binding OverflowItemsVerticalAlignment}"
                                  ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <docking:DockOverflowItemsPanel ItemsOrientation="{Binding DataContext.ItemsOrientation, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                TrackCount="{Binding DataContext.ActiveOverflowTracks, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                PrimarySlotCount="{Binding DataContext.TotalPrimarySlots, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                ItemExtentWidth="{Binding DataContext.ItemExtentWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                ItemExtentHeight="{Binding DataContext.ItemExtentHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border AllowDrop="True"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1.5"
                                        Margin="{Binding DataContext.DockItemMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                        PreviewMouseLeftButtonDown="OnDockItemPreviewMouseLeftButtonDown"
                                        PreviewMouseMove="OnDockItemMouseMove"
                                        DragOver="OnDockItemDragOver"
                                        Drop="OnDockItemDrop">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding LaunchCommand}"
                                              Header="Launch"
                                              Visibility="{Binding LauncherVisibility}" />
                                    <MenuItem Command="{Binding LaunchAsAdministratorCommand}"
                                              Header="Launch As Administrator"
                                              Visibility="{Binding LauncherVisibility}" />
                                    <Separator Visibility="{Binding LauncherVisibility}" />
                                    <MenuItem Command="{Binding EditCommand}" Header="Edit Item" />
                                    <MenuItem Command="{Binding OpenLocationCommand}"
                                              Header="Open Location"
                                              Visibility="{Binding OpenLocationVisibility}" />
                                    <MenuItem Command="{Binding RenameCommand}" Header="Rename" />
                                    <MenuItem Header="Move To Panel"
                                              ItemsSource="{Binding MoveTargets}"
                                              Visibility="{Binding MoveTargetsVisibility}">
                                        <MenuItem.ItemContainerStyle>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Header" Value="{Binding PanelName}" />
                                                <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.MoveToPanelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Setter Property="CommandParameter" Value="{Binding}" />
                                            </Style>
                                        </MenuItem.ItemContainerStyle>
                                    </MenuItem>
                                    <MenuItem Command="{Binding DuplicateCommand}" Header="Duplicate Item" />
                                    <MenuItem Command="{Binding DuplicateToNewPanelCommand}" Header="Duplicate To New Panel" />
                                    <MenuItem Command="{Binding RemoveCommand}" Header="Remove From Panel" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel>
                                <Border Width="{Binding DataContext.SeparatorSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Height="{Binding DataContext.SeparatorSlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Visibility="{Binding SeparatorVisibility}">
                                    <Border Width="{Binding DataContext.SeparatorLineWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="{Binding DataContext.SeparatorLineHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#66CBD5E1"
                                            CornerRadius="1" />
                                </Border>
                                <Grid Width="{Binding DataContext.ItemSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Visibility="{Binding LauncherVisibility}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Margin="{Binding DataContext.TopLabelMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Visibility="{Binding DataContext.TopLabelsVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock HorizontalAlignment="Center"
                                               Width="{Binding DataContext.LabelTextWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MinHeight="{Binding DataContext.LabelMinHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="{Binding DataContext.TextSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF9FAFB"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding DisplayName}"
                                               ToolTip="{Binding DisplayName}" />
                                </StackPanel>

                                <Grid Grid.Row="1"
                                      Height="{Binding DataContext.ItemSlotHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Button VerticalAlignment="{Binding DataContext.ItemButtonVerticalAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{StaticResource DockButtonStyle}"
                                            Command="{Binding LaunchCommand}"
                                            ToolTipService.IsEnabled="{Binding DataContext.HoverLabelsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTipService.Placement="{Binding DataContext.HoverLabelPlacement, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTipService.VerticalOffset="{Binding DataContext.HoverLabelVerticalOffset, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.ToolTip>
                                            <ToolTip Background="#F11E293B"
                                                     BorderBrush="#6638BDF8"
                                                     Foreground="#FFF8FAFC"
                                                     Padding="10,8"
                                                     PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Button}}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Opacity="0.72"
                                                               Text="{Binding TypeLabel}" />
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Grid>
                                            <Grid Width="{Binding DataContext.IconBackplateSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Height="{Binding DataContext.IconBackplateSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding GlyphVisibility}">
                                                <Ellipse Visibility="{Binding DataContext.CircleShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Fill="{Binding AccentBrush}" />
                                                <Border Visibility="{Binding DataContext.RoundedSquareShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Background="{Binding AccentBrush}"
                                                        CornerRadius="{Binding DataContext.IconBackplateRoundedSquareCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <Border Visibility="{Binding DataContext.SquareShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Background="{Binding AccentBrush}"
                                                        CornerRadius="0" />
                                                <Polygon Visibility="{Binding DataContext.HexagonShapeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Points="50,2 92,26 92,74 50,98 8,74 8,26"
                                                         Stretch="Fill"
                                                         Fill="{Binding AccentBrush}" />

                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="#FF0B1220"
                                                           Visibility="{Binding GlyphVisibility}"
                                                           Text="{Binding Glyph}" />
                                            </Grid>

                                            <Image MaxWidth="{Binding DataContext.IconArtworkSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   MaxHeight="{Binding DataContext.IconArtworkSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Stretch="Uniform"
                                                   Source="{Binding IconSource}"
                                                   Visibility="{Binding IconVisibility}" />
                                        </Grid>
                                    </Button>
                                </Grid>

                                <StackPanel Grid.Row="2"
                                            Margin="{Binding DataContext.BottomLabelMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Visibility="{Binding DataContext.BottomLabelsVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock HorizontalAlignment="Center"
                                               Width="{Binding DataContext.LabelTextWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MinHeight="{Binding DataContext.LabelMinHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="{Binding DataContext.TextSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF9FAFB"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding DisplayName}"
                                               ToolTip="{Binding DisplayName}" />
                                </StackPanel>
                                </Grid>
                            </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock x:Name="OverflowStartIndicator"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Panel.ZIndex="2"
                           Width="18"
                           Height="22"
                           FontSize="16"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#DDF8FAFC"
                           Background="#991E293B"
                           Text="&lt;"
                           Visibility="{Binding HorizontalOverflowIndicatorVisibility}" />
                <TextBlock x:Name="OverflowEndIndicator"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Panel.ZIndex="2"
                           Width="18"
                           Height="22"
                           FontSize="16"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#DDF8FAFC"
                           Background="#991E293B"
                           Text="&gt;"
                           Visibility="{Binding HorizontalOverflowIndicatorVisibility}" />
                <TextBlock x:Name="OverflowTopIndicator"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Panel.ZIndex="2"
                           Width="28"
                           Height="18"
                           FontSize="14"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#DDF8FAFC"
                           Background="#991E293B"
                           Text="^"
                           Visibility="{Binding VerticalOverflowIndicatorVisibility}" />
                <TextBlock x:Name="OverflowBottomIndicator"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Panel.ZIndex="2"
                           Width="28"
                           Height="18"
                           FontSize="14"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#DDF8FAFC"
                           Background="#991E293B"
                           Text="v"
                           Visibility="{Binding VerticalOverflowIndicatorVisibility}" />
            </Grid>
        </Grid>
    </Border>
    </Grid>
</Window>

<Window x:Class="DockLauncher.AppHost.Docking.FolderFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="420"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True">
    <Border Style="{StaticResource FlyoutChromeStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="2,0,2,12">
                <StackPanel>
                    <TextBlock MaxWidth="360"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentFolderName}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#FF94A3B8"
                               Text="{Binding EntryCountLabel}" />
                </StackPanel>
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Padding="14,7"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#FF334155"
                            BorderBrush="#FF64748B"
                            Command="{Binding OpenInExplorerCommand}"
                            Content="Open In Explorer" />
                </Grid>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Entries}"
                     Visibility="{Binding TilesVisibility}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource FlyoutScrollBarStyle}" />
                </ListBox.Resources>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="86"
                                   ItemHeight="96" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource FlyoutItemButtonStyle}"
                                Width="86"
                                Height="96"
                                Command="{Binding OpenCommand}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding OpenCommand}" Header="Open" />
                                    <Separator />
                                    <MenuItem Command="{Binding OpenLocationCommand}" Header="Open Location" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Grid>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Style="{StaticResource FlyoutTileIconBadgeStyle}"
                                            CornerRadius="{Binding DataContext.FlyoutIconCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid>
                                            <Image MaxWidth="34"
                                                   MaxHeight="34"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Source="{Binding IconSource}"
                                                   Visibility="{Binding IconVisibility}" />
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="#FFF8FAFC"
                                                       Visibility="{Binding GlyphVisibility}"
                                                       Text="{Binding Glyph}" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Width="78"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF8FAFC"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Name}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Entries}"
                     Visibility="{Binding ListVisibility}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource FlyoutScrollBarStyle}" />
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource FlyoutItemButtonStyle}"
                                Command="{Binding OpenCommand}">
                            <Border Style="{StaticResource FlyoutItemCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FlyoutIconBadgeStyle}"
                                            CornerRadius="{Binding DataContext.FlyoutIconCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid>
                                            <Image MaxWidth="24"
                                                   MaxHeight="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Source="{Binding IconSource}"
                                                   Visibility="{Binding IconVisibility}" />
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="#FFF8FAFC"
                                                       Visibility="{Binding GlyphVisibility}"
                                                       Text="{Binding Glyph}" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>

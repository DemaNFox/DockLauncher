<Window x:Class="DockLauncher.DragProbe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DockLauncher Drag Probe"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#FF111827"
        Foreground="#FFF8FAFC"
        AllowDrop="True"
        DragEnter="OnDragEvent"
        DragOver="OnDragEvent"
        Drop="OnDrop">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="170" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Width="120"
                        Height="32"
                        Margin="8,0,0,0"
                        Click="OnClearClick"
                        Content="Clear" />
                <Button Width="120"
                        Height="32"
                        Margin="8,0,0,0"
                        Click="OnOpenLogsClick"
                        Content="Open Logs" />
            </StackPanel>
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Drag Probe" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#FFCBD5E1"
                           Text="{Binding LogDirectoryText}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,12"
                BorderBrush="#FF38BDF8"
                BorderThickness="2"
                Background="#FF172033"
                CornerRadius="6"
                AllowDrop="True"
                DragEnter="OnDragEvent"
                DragOver="OnDragEvent"
                Drop="OnDrop">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="Drop taskbar/start/menu items here" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left"
                       FontWeight="SemiBold"
                       Text="Last capture" />
            <TextBlock HorizontalAlignment="Right"
                       Foreground="#FFCBD5E1"
                       Text="{Binding LastCaptureText}" />
        </DockPanel>

        <Border Grid.Row="3"
                BorderBrush="#FF334155"
                BorderThickness="1"
                Background="#FF0B1220"
                CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TextBox Padding="12"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="13"
                         Foreground="#FFF8FAFC"
                         IsReadOnly="True"
                         Text="{Binding ReportText, Mode=OneWay}"
                         TextWrapping="NoWrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
